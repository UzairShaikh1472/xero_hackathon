# Primary: Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Primary model; on 503/429 the client falls back to other Gemini models.
GEMINI_MODEL=gemini-2.0-flash

# Fallback: Cerebras (OpenAI-compatible) — https://cloud.cerebras.ai/
# Used when Gemini is rate-limited, overloaded, or unavailable.
# For SambaNova, use your key from https://cloud.sambanova.ai/ and set
# CEREBRAS_BASE_URL in src/lib/llm.ts to https://api.sambanova.ai/v1
AI_API_KEY=
# Optional override (default: gpt-oss-120b). List models via GET /v1/models.
# Other common IDs on some accounts: gemma-4-31b, zai-glm-4.7, llama-3.3-70b
AI_MODEL=gpt-oss-120b
