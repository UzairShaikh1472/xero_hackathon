PORT=3001
NODE_ENV=development
FRONTEND_APP_URL=http://localhost:8080
PUBLIC_BASE_URL=http://localhost:3001
USE_XERO_FALLBACK=false

# Required for live Xero - copy from https://developer.xero.com/app/manage
# Redirect URI in Xero app must be: http://localhost:3001/api/xero/callback
XERO_STATE_SALT=change-me
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3001/api/xero/callback
XERO_SCOPES=openid profile email offline_access accounting.transactions accounting.contacts accounting.settings accounting.reports.read

# Primary: Gemini - https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Fallback: Cerebras (OpenAI-compatible)
AI_API_KEY=
AI_MODEL=gpt-oss-120b

# SMTP email delivery (used for receivables under 14 days overdue)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Twilio Voice (optional legacy outbound calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Test delivery — when set, all outbound emails go here instead of Xero contacts
COMMUNICATIONS_TEST_EMAIL=
COMMUNICATIONS_TEST_PHONE=

# Finance team inbox for post-call transcripts and summaries
CALL_REPORT_EMAIL=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_DEMO_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5

# Browser voice agent (optional — Gemini fallback used when Vapi is not set)
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=

# ElevenLabs TTS — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
